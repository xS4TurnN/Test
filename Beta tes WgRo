-- ==================== ОСНОВНЫЕ ФУНКЦИИ ====================
local ESPObjects = {}
local GunObjects = {}
local ShotBigButton = nil

local function getRole(plr)
    if not plr.Character then return "Innocent" end
    if plr.Character:FindFirstChild("Knife") or plr.Backpack:FindFirstChild("Knife") then return "Murderer" end
    if plr.Character:FindFirstChild("Gun") or plr.Backpack:FindFirstChild("Gun") then return "Sheriff" end
    return "Innocent"
end

local function createShotBigButton()
    if ShotBigButton then return end
    ShotBigButton = Instance.new("TextButton")
    ShotBigButton.Size = UDim2.new(0, 150, 0, 80)
    ShotBigButton.Position = UDim2.new(0.75, 0, 0.6, 0)
    ShotBigButton.BackgroundColor3 = Color3.fromRGB(200, 20, 20)
    ShotBigButton.Text = "🔫 SHOT\nMURDERER"
    ShotBigButton.TextColor3 = Color3.new(1,1,1)
    ShotBigButton.Font = Enum.Font.GothamBold
    ShotBigButton.TextSize = 16
    ShotBigButton.Parent = ScreenGui
    Instance.new("UICorner", ShotBigButton).CornerRadius = UDim.new(0, 14)

    local dragging = false
    ShotBigButton.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = true end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            ShotBigButton.Position = ShotBigButton.Position + UDim2.new(0, input.Position.X - ShotBigButton.Position.X.Offset, 0, input.Position.Y - ShotBigButton.Position.Y.Offset)
        end
    end)
    UserInputService.InputEnded:Connect(function() dragging = false end)

    ShotBigButton.MouseButton1Click:Connect(function()
        if not ShotMurderer then return end
        for _, plr in ipairs(Players:GetPlayers()) do
            if plr \~= LocalPlayer and getRole(plr) == "Murderer" and plr.Character then
                local root = plr.Character:FindFirstChild("HumanoidRootPart")
                if root then
                    Camera.CFrame = CFrame.lookAt(Camera.CFrame.Position, root.Position)
                    mouse1click()
                end
            end
        end
    end)
end

-- Основной цикл
RunService.RenderStepped:Connect(function()
    -- ESP All
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr == LocalPlayer or not plr.Character then continue end
        local root = plr.Character:FindFirstChild("HumanoidRootPart")
        if not root then continue end

        local role = getRole(plr)
        local color = role == "Murderer" and Color3.fromRGB(255,0,0) or (role == "Sheriff" and Color3.fromRGB(0,100,255) or Color3.fromRGB(0,255,0))

        if not ESPObjects[plr] then
            local box = Drawing.new("Square")
            box.Thickness = 2
            box.Filled = false
            box.Transparency = 1
            ESPObjects[plr] = box
        end

        local box = ESPObjects[plr]
        local pos, onScreen = Camera:WorldToViewportPoint(root.Position + Vector3.new(0,3,0))

        if ESPAll and onScreen then
            box.Size = Vector2.new(1800 / pos.Z, 2800 / pos.Z)
            box.Position = Vector2.new(pos.X - box.Size.X/2, pos.Y - box.Size.Y/2)
            box.Color = color
            box.Visible = true
        else
            box.Visible = false
        end
    end

    -- ESP Gun
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("Model") and string.find(obj.Name:lower(), "gun") and obj:FindFirstChild("Handle") then
            if not GunObjects[obj] then
                local txt = Drawing.new("Text")
                txt.Text = "🔫 GUN"
                txt.Color = Color3.fromRGB(255, 215, 0)
                txt.Size = 18
                GunObjects[obj] = txt
            end
            local txt = GunObjects[obj]
            local pos, onScreen = Camera:WorldToViewportPoint(obj.Handle.Position)
            if ESPGun and onScreen then
                txt.Position = Vector2.new(pos.X, pos.Y)
                txt.Visible = true
            else
                txt.Visible = false
            end
        end
    end

    -- Shot Murderer Button
    if ShotMurderer and not ShotBigButton then
        createShotBigButton()
    end

    -- Crosshair
    if CrosshairEnabled then
        -- Простой текст прицел
        local ch = Drawing.new("Text")
        ch.Text = "•"
        ch.Color = Color3.fromRGB(0, 255, 200)
        ch.Size = 24
        ch.Center = true
        ch.Outline = true
        ch.Position = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
        ch.Visible = true
        game:GetService("RunService").RenderStepped:Wait()
        ch:Remove()
    end
end)

